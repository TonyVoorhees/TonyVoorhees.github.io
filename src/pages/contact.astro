---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/sections/contact/Hero.astro";
import Form from "../components/sections/contact/Form.astro";
import Aside from "../components/sections/contact/Aside.astro";
import { meta } from "../data/contact";
---
<Layout active="contact" title={meta.title} description={meta.description}>
  <Hero />
  <section class="px-5 sm:px-6 md:px-8 pt-8 md:pt-14 pb-16 md:pb-20">
    <div
      class="mx-auto grid gap-12 md:gap-16 items-start grid-cols-1 md:[grid-template-columns:1.4fr_1fr] max-w-(--container-wide)"
    >
      <Form />
      <Aside />
    </div>
  </section>
</Layout>
