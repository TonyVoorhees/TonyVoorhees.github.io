---
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import authorPortrait from "../../../assets/journal/journal-detail.png";

interface Props {
  entry: CollectionEntry<"journal">;
}
const { entry } = Astro.props;
---
<section class="px-5 sm:px-6 md:px-8 py-12 md:py-16">
  <div class="mx-auto flex gap-5 md:gap-6 items-center border-t border-b border-hairline py-6 md:py-8 max-w-(--container-prose)">
    <div class="shrink-0 w-20">
      {/* Square author portrait, rendered B&W to match the editorial mono
          treatment. Displayed at 80px (w-20); widths cover DPR 1–3. */}
      <Image
        src={authorPortrait}
        alt={entry.data.author}
        widths={[80, 160, 240]}
        sizes="80px"
        loading="lazy"
        decoding="async"
        class="w-full aspect-square object-cover grayscale"
      />
    </div>
    <div>
      <p class="font-serif text-lg md:text-xl m-0 tracking-tight">{entry.data.author}</p>
      {entry.data.authorBio && (
        <p class="text-sm text-text-muted mt-1.5 m-0 leading-[1.45]">{entry.data.authorBio}</p>
      )}
    </div>
  </div>
</section>
