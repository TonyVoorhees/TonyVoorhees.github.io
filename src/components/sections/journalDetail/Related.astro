---
import type { CollectionEntry } from "astro:content";
import Placeholder from "../../Placeholder.astro";
import SectionTag from "../../SectionTag.astro";

interface Props {
  related: CollectionEntry<"journal">[];
}
const { related } = Astro.props;
---
{related.length > 0 && (
  <section class="px-5 sm:px-6 md:px-8 pt-6 md:pt-10 pb-16 md:pb-20">
    <div class="mx-auto max-w-(--container-wide)">
      <SectionTag num="—" label="Related" />
      <div class="mt-8 md:mt-10 grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        {related.map((j) => (
          <a href={`/journal/${j.id}`} class="cursor-pointer grid gap-5 md:gap-6 [grid-template-columns:5fr_7fr]">
            <Placeholder
              image={j.data.coverImage}
              ratio="3 / 2"
              label={j.data.img}
              alt={`${j.data.title} — by ${j.data.author}`}
              sizes="(min-width: 768px) 42vw, 100vw"
            />
            <div>
              <p class="font-mono uppercase text-micro text-text-muted m-0 tracking-mono-loose">{j.data.tag}</p>
              <h3 class="font-serif font-normal text-lg md:text-title-sm mt-2 md:mt-3 m-0 tracking-snug" style="line-height: 1.25;">
                {j.data.title}
              </h3>
              <p class="font-mono text-micro text-text-muted mt-3 md:mt-4 uppercase tracking-mono">
                {j.data.dateLabel} · {j.data.read}
              </p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
)}
