---
import SectionTag from "../../SectionTag.astro";
import { faq } from "../../../data/services";
---
{/*
  Multi-open accordion. The Alpine state is an array of indices currently
  expanded — `toggle(i)` flips one index in/out, `isOpen(i)` answers the
  per-row queries. The first item starts expanded so the section reads as
  "alive" on first scroll-in; everything else is the user's choice.

  Why multi-open vs single-open: most readers compare two or three
  questions before deciding to scroll to contact (e.g. scope + timeline
  + pricing). Forcing single-open makes them play whack-a-mole to
  cross-check. The cost of multi-open is a slightly longer total scroll
  when everything is expanded, which is fine — the section is one
  per page and the user opts into it.
*/}
<section class="px-5 sm:px-6 md:px-8 pt-20 md:pt-32 pb-16 md:pb-20">
  <div
    class="mx-auto grid gap-8 md:gap-20 grid-cols-1 md:[grid-template-columns:1fr_2fr] max-w-(--container-band)"
    x-data="{
      open: [0],
      toggle(i) {
        this.open = this.open.includes(i)
          ? this.open.filter((x) => x !== i)
          : [...this.open, i];
      },
      isOpen(i) { return this.open.includes(i); }
    }"
  >
    <SectionTag num={faq.sectionTag.num} label={faq.sectionTag.label} />

    <div>
      {faq.items.map((f, i) => (
        <div class="border-t border-hairline py-6">
          <button
            type="button"
            x-on:click={`toggle(${i})`}
            x-bind:aria-expanded={`isOpen(${i})`}
            class="bg-transparent border-none p-0 w-full flex justify-between items-center gap-6 text-left text-text cursor-pointer"
          >
            <h4
              class="font-serif font-normal m-0 tracking-snug"
              style="font-size: clamp(1.25rem, 2vw, 1.75rem);"
            >
              {f.q}
            </h4>
            <span
              class="font-mono text-title-sm text-text-muted transition-transform duration-300"
              x-bind:style={`{ transform: isOpen(${i}) ? 'rotate(45deg)' : 'none' }`}
            >+</span>
          </button>
          {/*
            grid-template-rows: 0fr ↔ 1fr trick.

            The classic max-height transition feels slow on close because
            you have to clamp at a value larger than any possible content
            (e.g. 320px), and the first ~60% of the close animation is
            shrinking from 320px down to the actual content height (say
            120px) — entirely invisible to the user because the content
            doesn't overflow that interim range. By the time max-height
            drops below the real content height and visible collapse
            starts, half the duration is already gone.

            The grid trick animates the row's intrinsic size: 0fr collapses
            to zero, 1fr expands to whatever the content actually measures.
            No overshoot, no dead frames. The inner div needs overflow:hidden
            so content clips cleanly during the animation. */}
          <div
            class="grid"
            style="transition: grid-template-rows 350ms cubic-bezier(0.22, 1, 0.36, 1); grid-template-rows: 0fr;"
            x-bind:style={`{ gridTemplateRows: isOpen(${i}) ? '1fr' : '0fr' }`}
          >
            <div class="overflow-hidden">
              <p class="text-base leading-[1.65] text-text-muted m-0 mt-5 max-w-(--container-note)">
                {f.a}
              </p>
            </div>
          </div>
        </div>
      ))}
      <div class="border-t border-hairline"></div>
    </div>
  </div>
</section>
