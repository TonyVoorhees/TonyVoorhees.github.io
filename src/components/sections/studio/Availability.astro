---
import Btn from "../../Btn.astro";
import { availability } from "../../../data/studio";
---
<section class="px-5 sm:px-6 md:px-8 pt-20 md:pt-32 pb-16 md:pb-20">
  <div
    class="mx-auto px-6 sm:px-10 md:px-16 py-10 md:py-14 border border-hairline flex justify-between items-start md:items-center gap-6 md:gap-8 flex-col md:flex-row max-w-(--container)"
  >
    <div>
      <p class="font-mono uppercase text-label text-text-muted m-0 flex items-center gap-2.5 tracking-mono-loose">
        <span class="pulse-dot inline-block rounded-full bg-accent size-2" aria-hidden="true"></span>
        {availability.label}
      </p>
      <h3 class="font-serif font-350 m-0 mt-4 tracking-display" style="font-size: clamp(1.5rem, 3.6vw, 3rem); line-height: 1.1;">
        {availability.title.lead} <span class="italic">{availability.title.accent}</span>.
      </h3>
    </div>
    <Btn href={availability.cta.href} variant="primary">{availability.cta.label}</Btn>
  </div>
</section>
