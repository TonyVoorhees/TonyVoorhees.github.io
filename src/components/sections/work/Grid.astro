---
import type { CollectionEntry } from "astro:content";
import Placeholder from "../../Placeholder.astro";

interface Props {
  items: CollectionEntry<"work">[];
}
const { items } = Astro.props;
---
<section class="px-5 sm:px-6 md:px-8 pt-6 md:pt-10 pb-16 md:pb-20">
  <div class="mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-10 max-w-(--container-wide) grid-flow-dense">
    {items.map((w) => (
      <a
        href={`/work/${w.id}`}
        class="block cursor-pointer"
        x-show={`filter === 'All' || filter === '${w.data.type}'`}
        x-bind:class={`{ 'sm:col-span-2': ${w.data.span} === 2 }`}
        data-animate
      >
        <Placeholder
          image={w.data.coverImage}
          ratio={w.data.span === 2 ? "16 / 9" : "4 / 5"}
          label={w.data.img}
          alt={`${w.data.name} — ${w.data.client}, ${w.data.year}`}
          sizes={w.data.span === 2 ? "(min-width: 640px) 66vw, 100vw" : "(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"}
        />
        <div class="flex justify-between items-baseline mt-4 gap-4">
          <div>
            <h2 class="font-serif font-normal m-0 tracking-snug" style={`font-size: clamp(20px, 2.2vw, ${w.data.span === 2 ? "32px" : "24px"});`}>
              {w.data.name}
            </h2>
            <p class="font-mono uppercase text-label text-text-muted mt-1.5 m-0 tracking-mono">
              {w.data.client}
            </p>
          </div>
          <div class="text-right">
            <span class="font-mono text-meta text-text-muted">—{w.data.year}</span>
            <p class="font-mono uppercase text-micro text-text-muted border border-hairline px-2 py-0.5 inline-block ml-2 mt-2 m-0 tracking-mono">
              {w.data.type}
            </p>
          </div>
        </div>
      </a>
    ))}
  </div>
</section>
