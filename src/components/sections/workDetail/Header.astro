---
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"work">;
  index: number;
  total: number;
}
const { entry, index, total } = Astro.props;

// Editorial flourish — italicise the last word of the project name so the
// display heading carries the same character as the Kjeld and Meridian
// case studies. Works on multi-word names; single-word names are returned
// as-is and rely on the design's larger typographic weight to carry them.
const parts = entry.data.name.split(" ");
const lead = parts.length === 1 ? "" : parts.slice(0, -1).join(" ") + " ";
const accent = parts[parts.length - 1];
---
<section class="px-5 sm:px-6 md:px-8 pt-6 md:pt-10 pb-10 md:pb-16">
  <div class="mx-auto max-w-(--container-wide)">
    <div
      class="font-mono uppercase text-label text-text-muted flex justify-between gap-4 tracking-mono"
    >
      <a href="/work" class="hover-line">← All work</a>
      <span>Case study {String(index).padStart(2, "0")} / {String(total).padStart(2, "0")}</span>
    </div>

    <h1
      class="font-serif font-350 m-0 mt-10 md:mt-16 leading-[0.92] tracking-hero-xl text-balance"
      style="font-size: clamp(3rem, 10vw, 11rem);"
    >
      {lead}<span class="italic">{accent}</span>
    </h1>

    <div class="mt-6 md:mt-8 flex gap-4 md:gap-6 items-baseline flex-wrap">
      <p
        class="font-mono uppercase text-xs text-text-muted m-0 tracking-mono-loose"
      >
        {entry.data.client} · {entry.data.year}
      </p>
      <div class="flex gap-2 flex-wrap">
        {entry.data.chips.map((t) => (
          <span
            class="font-mono uppercase text-micro px-2.5 py-1 border border-hairline text-text-muted tracking-mono"
          >
            {t}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>
