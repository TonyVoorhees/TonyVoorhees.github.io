---
import type { CollectionEntry } from "astro:content";
import Placeholder from "../../Placeholder.astro";

interface Props {
  next: CollectionEntry<"work"> | null;
}
const { next } = Astro.props;

const parts = next?.data.name.split(" ") ?? [];
const lead = parts.length <= 1 ? "" : parts.slice(0, -1).join(" ") + " ";
const accent = parts[parts.length - 1] ?? "";
---
{next ? (
  <section class="px-5 sm:px-6 md:px-8 pt-6 md:pt-10 pb-16 md:pb-20">
    <div class="mx-auto max-w-(--container-wide)">
      <a
        href={`/work/${next.id}`}
        class="block cursor-pointer py-8 md:py-12 border-t border-b border-hairline hover-line"
      >
        <div class="flex justify-between items-center gap-6 md:gap-8">
          <div>
            <p class="font-mono uppercase text-label text-text-muted m-0 tracking-mono-loose">
              Next project —
            </p>
            <h2
              class="font-serif font-350 m-0 mt-4 md:mt-5 leading-none tracking-display-lg"
              style="font-size: clamp(1.75rem, 5.5vw, 5.5rem);"
            >
              {lead}<span class="italic">{accent}</span> →
            </h2>
            <p class="font-mono uppercase text-label text-text-muted mt-3 md:mt-4 m-0 tracking-mono-loose">
              {next.data.type} · {next.data.client} · {next.data.year}
            </p>
          </div>
          <div class="hidden md:block w-80 shrink-0 grow-0 basis-80">
            <Placeholder
              image={next.data.coverImage}
              ratio="4 / 3"
              label={next.data.img}
              alt={`${next.data.name} — ${next.data.client}`}
              sizes="(min-width: 640px) 320px, 100vw"
              w={320}
              h={240}
            />
          </div>
        </div>
      </a>
    </div>
  </section>
) : (
  <section class="px-5 sm:px-6 md:px-8 pt-6 md:pt-10 pb-20 md:pb-32">
    <div class="mx-auto max-w-(--container-wide)">
      <div class="border-t border-hairline pt-8 md:pt-12 flex justify-between items-baseline gap-6 flex-wrap">
        <p class="font-mono uppercase text-label text-text-muted m-0 tracking-mono-loose">
          End of archive — Studio Nord, est. 2018
        </p>
        <a href="/work" class="hero-cta text-text-muted">
          <span>Return to the index</span>
          <span class="hero-cta__arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>
)}
