---
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"work">;
}
const { entry } = Astro.props;

const cells = [
  { k: "Client", v: entry.data.client },
  { k: "Year", v: entry.data.year },
  { k: "Scope", v: entry.data.scope },
  { k: "Recognition", v: entry.data.recognition },
];
---
{/*
  Sticky banner — stays under the fixed header while scrolling through the body.

  The `top` calc places the section's top edge at the header's bottom edge minus
  1px, so the InfoBar's `border-t` overlaps the header's `border-b` into a
  single hairline (no double-line, no gap). Reads --header-height-scrolled
  from @theme so the value lives in one place — keep it in sync if you change
  the header's padding or content height.

  Both top and bottom padding (originally `py-20`) live as margins instead.
  Padding would be inside the sticky element's bounding box — with `bg-bg`,
  those 80px above and below would become an opaque "lid" that visually
  covers body content as the page scrolls behind it. Margins live in
  document flow, so they preserve the 80px breathing room without dragging
  the sticky element's painted area beyond its hairline borders.
*/}
<section
  class="px-5 sm:px-6 md:px-8 my-12 md:my-20 static md:sticky z-10 bg-bg under-header"
>
  {/*
    Mobile: 2×2 grid, static (scrolls with the page — sticky on a 375px
    viewport eats too much screen and the metadata isn't worth pinning at
    that size). Desktop: 4-column grid, sticky under the header (the
    classic editorial pin behaviour).

    Border rules:
      - Mobile (2 cols): left border on odd-index cells (1, 3); top border
        on row-2 cells (2, 3).
      - Desktop (4 cols): left border on all but the first cell.
  */}
  <div
    class="mx-auto border-t border-b border-hairline grid grid-cols-2 md:grid-cols-4 max-w-(--container-wide)"
  >
    {cells.map((c, i) => {
      const mobileLeft = i % 2 === 1;
      const mobileTop = i >= 2;
      return (
        <div
          class:list={[
            "py-5 md:py-6 px-3 sm:px-4 min-w-0",
            mobileLeft && "border-l border-hairline",
            mobileTop && "border-t border-hairline md:border-t-0",
            !mobileLeft && i !== 0 && "md:border-l md:border-hairline",
            i === 0 && "md:border-l-0",
          ]}
        >
          <p class="font-mono uppercase text-micro text-text-muted m-0 tracking-mono-loose">
            {c.k}
          </p>
          <p
            class="font-serif font-normal m-0 mt-2 md:mt-2.5 break-words tracking-tight"
            style={`font-size: clamp(16px, 1.6vw, 22px); color: ${c.v === "—" ? "var(--color-text-muted)" : "var(--color-text)"};`}
          >
            {c.v}
          </p>
        </div>
      );
    })}
  </div>
</section>
