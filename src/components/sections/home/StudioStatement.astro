---
import SectionTag from "../../SectionTag.astro";
import { studioStatement } from "../../../data/home";

// Word-by-word mask reveal. Each word renders inside a [data-word-mask]
// (overflow:hidden) wrapping a [data-word] inner span that starts
// translated 110% below the line; on .is-in each word slides up to its
// natural position. The 45ms-per-word stagger is set inline per span as
// transition-delay. Behaviour and visuals live in [data-animate="words"]
// in src/styles/base.css. Pure transform — no opacity fade — so the
// effect reads as a curtain rise rather than a wipe.
const STUDIO_WORD_DELAY_MS = 45;
const studioWords = studioStatement.body.split(" ");
---
<section class="bg-surface pt-20 md:pt-24 xl:pt-28 pb-20 md:pb-24 xl:pb-28 px-5 sm:px-6 md:px-8">
  <div class="mx-auto grid gap-10 grid-cols-1 md:[grid-template-columns:1fr_2fr] max-w-(--container)">
    <SectionTag num={studioStatement.sectionTag.num} label={studioStatement.sectionTag.label} />
    <div>
      <p
        class="font-light m-0 font-sans tracking-snug"
        style="font-size: clamp(1.25rem, 2.6vw, 2.5rem); line-height: 1.3;"
        data-animate="words"
      >
        {studioWords.flatMap((word, i, arr) => [
          <span data-word-mask style={i === 0 ? "margin-left: 2.5em" : undefined}><span data-word style={`transition-delay: ${i * STUDIO_WORD_DELAY_MS}ms`}>{word}</span></span>,
          i < arr.length - 1 ? " " : null,
        ])}
      </p>

      <div class="mt-12 md:mt-20 border-t border-hairline pt-7 grid grid-cols-1 sm:grid-cols-3 gap-8" data-animate>
        {studioStatement.values.map((v) => (
          <div>
            <span class="font-mono text-label text-accent tracking-mono">{v.n}</span>
            <h4 class="font-serif font-normal text-2xl md:text-title mt-2.5 mb-2 tracking-snug">{v.name}</h4>
            <p class="text-sm text-text-muted m-0 leading-[1.5]">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
