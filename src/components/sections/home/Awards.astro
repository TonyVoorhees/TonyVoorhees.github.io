---
import SectionTag from "../../SectionTag.astro";
import { awards } from "../../../data/home";
---
<section class="pt-24 md:pt-36 xl:pt-40 pb-16 md:pb-18 xl:pb-20 px-5 sm:px-6 md:px-8">
  <div class="mx-auto grid items-start gap-10 md:gap-20 grid-cols-1 md:[grid-template-columns:1fr_1.4fr] max-w-(--container)">
    <div>
      <SectionTag num={awards.sectionTag.num} label={awards.sectionTag.label} />
      <h2
        class="font-serif font-350 m-0 mt-5 md:mt-6 leading-none tracking-display-lg text-section"
        data-animate="rise"
      >
        {awards.title.lead}<br /><span class="italic">{awards.title.accent}</span>.
      </h2>
      <p
        class="mt-6 md:mt-7 text-text-muted leading-body max-w-[360px]"
        data-animate="rise"
        style="--reveal-delay: 200ms"
      >
        {awards.intro}
      </p>
    </div>

    {/* overflow-hidden contains the per-row 32px horizontal pre-translate
        — without it the off-canvas frame can leak past the section's right
        edge on iOS (where `body { overflow-x: clip }` doesn't always
        suppress descendants). */}
    <ul class="list-none p-0 m-0 overflow-hidden">
      {awards.items.map((a) => (
        <li
          class="award-row py-6 md:py-9 border-t border-hairline grid items-baseline gap-6 md:gap-8 [grid-template-columns:1fr_auto]"
          data-animate
        >
          <div>
            <h3 class="font-serif font-normal m-0 leading-[1.1] tracking-snug" style="font-size: clamp(1.25rem, 2.2vw, 2rem);">{a.name}</h3>
            <p class="font-mono uppercase text-label text-text-muted mt-2.5 md:mt-3 m-0 tracking-mono-loose">{a.year}</p>
          </div>
          <span class="font-serif italic font-350 text-text inline-flex items-baseline gap-2.5 tracking-display-lg" style="font-size: clamp(2.5rem, 4.5vw, 4rem); line-height: 0.9;">
            {String(a.count).padStart(2, "0")}
            <span class="font-mono text-body text-text-muted not-italic font-normal" style="letter-spacing: 0;">×</span>
          </span>
        </li>
      ))}
      <li class="border-t border-hairline"></li>
    </ul>
  </div>
</section>

<style is:global>
  /*
    Right-to-left slide for each award row — matches the Press list on the
    studio page. Each row carries `data-animate` so the global
    IntersectionObserver in Layout.astro reveals them individually as the
    viewport reaches each one.

    `:not(.is-in)` scopes the horizontal override to the INITIAL state.
    Without it, this rule's specificity (1 class + 1 attribute) ties with
    the global `[data-animate].is-in` rule but ships later in the cascade
    — so it would also override the resting state's `transform: none`,
    leaving each item permanently shifted +32px right and the slide-in
    invisible. The :not bumps specificity AND ensures the override
    de-activates the moment the IO adds `.is-in`.
  */
  .award-row[data-animate]:not(.is-in) {
    transform: translate3d(32px, 0, 0);
  }
</style>
