---
import SectionTag from "../../SectionTag.astro";
import { clientsBand } from "../../../data/home";

// Duplicate the list — the marquee animates a 50% translate so the seam
// is invisible and the loop is seamless.
const items = [...clientsBand.names, ...clientsBand.names];
---
<section class="pt-20 md:pt-28 xl:pt-32 pb-16 md:pb-18 xl:pb-20">
  <div class="mx-auto px-5 sm:px-6 md:px-8 max-w-(--container)">
    <SectionTag num={clientsBand.sectionTag.num} label={clientsBand.sectionTag.label} />
  </div>
  <div class="marquee-wrap mt-8 md:mt-12 overflow-hidden">
    <div class="marquee-track">
      {items.map((c) => (
        <div class="flex items-center justify-center py-6 md:py-10 px-8 md:px-14 font-serif italic font-normal text-xl md:text-2xl text-text-muted whitespace-nowrap tracking-tight min-w-45">
          {c}
        </div>
      ))}
    </div>
  </div>
</section>
