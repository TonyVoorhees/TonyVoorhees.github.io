---
/**
 * Site footer. Three columns + a thin meta row, over a giant centred
 * Studio Nord wordmark.
 *
 * Columns:
 *   1. Brand block — wordmark, tagline (italic serif), address
 *   2. Navigate    — primary nav (`nav` in site.ts)
 *   3. Elsewhere   — social links
 *
 * Meta row: back-of-book / legal links (`utilityLinks`) + copyright.
 *
 * The huge wordmark at the bottom uses Fraunces' opsz=144 axis so the
 * proportions stay graceful at editorial display size.
 */
import Wordmark from "./Wordmark.astro";
import { site, footerGroups, utilityLinks } from "../data/site";
---
<footer
  class="bg-bg border-t border-hairline mt-20 md:mt-32 pt-14 md:pt-20 px-5 sm:px-6 md:px-8"
>
  <div
    class="mx-auto grid gap-10 md:gap-16 pb-14 md:pb-20 grid-cols-2 md:[grid-template-columns:2fr_1fr_1fr] max-w-(--container)"
  >
    {/* Brand block — spans both columns on mobile so Navigate / Elsewhere
        sit side-by-side beneath it. */}
    <div class="col-span-2 md:col-span-1">
      <Wordmark size={28} inline={false} />
      <p
        class="font-serif italic font-light mt-5 md:mt-6 max-w-[380px]"
        style="font-size: clamp(18px, 2.4vw, 22px); line-height: 1.35;"
      >
        {site.tagline}
      </p>
      <p
        class="font-mono uppercase text-label text-text-muted mt-6 md:mt-7 tracking-mono"
      >
        {site.address}
      </p>
    </div>

    {/* Footer columns */}
    {footerGroups.map((group) => (
      <div>
        <p
          class="font-mono uppercase text-label text-text-muted mb-4 md:mb-5 tracking-mono-loose"
        >
          {group.title}
        </p>
        <ul class="list-none p-0 m-0 flex flex-col gap-2.5">
          {group.links.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={[
                  "hover-line text-body",
                  link.secondary && "text-text-muted",
                ]}
                {...(link.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
              >
                {link.label}{link.external && " ↗"}
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}

  </div>

  {/* Back-of-book meta row — utility / legal links + copyright. Kept out of
      the Navigate column so it stays focused on primary wayfinding; collapses
      to a stack on narrow screens. */}
  <div
    class="mx-auto max-w-(--container) flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between border-t border-hairline py-6"
  >
    <ul
      class="list-none p-0 m-0 flex flex-wrap items-center gap-y-1 font-mono uppercase text-label tracking-mono"
    >
      {utilityLinks.map((link, i) => (
        <li class="flex items-center">
          {/* py-1.5 lifts the tap target to ~30px (≥24px) for WCAG 2.5.8
              target-size on mobile. Native hover underline instead of
              `hover-line` here, since the animated underline sits at the box
              bottom and the padding would detach it from the text. */}
          <a
            href={link.href}
            class="py-1.5 text-text-muted hover:text-text hover:underline underline-offset-4 transition-colors"
          >
            {link.label}
          </a>
          {/* Separator trails the link so a wrap never orphans a leading "·". */}
          {i < utilityLinks.length - 1 && (
            <span aria-hidden="true" class="text-text-muted/50 mx-3">·</span>
          )}
        </li>
      ))}
    </ul>
    <p
      class="font-mono text-label text-text-muted whitespace-pre-line m-0 tracking-mono"
    >
      {site.copyright}
    </p>
  </div>

  {/* Giant centred wordmark */}
  <div class="overflow-hidden border-t border-hairline">
    <h2
      class="font-serif font-normal m-0 pt-2 tracking-hero-xl opsz-display"
      style="font-size: clamp(6rem, 22vw, 12rem); line-height: 0.85;"
    >
      <span class="italic">Tony Voorhees</span>
      <span class="inline-block" style="width: 0.06em;">Studio</span>
    </h2>
  </div>
</footer>
