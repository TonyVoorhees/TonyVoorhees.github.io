---
/**
 * Site header. Fixed at the top.
 *
 * Layout:
 *   - Compact (<lg): flex row — logo on the left, theme toggle + hamburger
 *     on the right. No middle column so nothing can drift toward the centre.
 *   - Desktop (lg+): three-column grid — logo / nav / actions. The nav only
 *     appears at lg because the six-item inline nav + logo + toggle measure
 *     ~820px; forcing it on at md (768px) overflowed the toggle off-screen
 *     in the 769–820px band. lg gives it the room it actually needs.
 *
 * Scroll behaviour (Alpine):
 *   - After 40px of scroll: padding tightens, background gains backdrop blur
 *     and a hairline bottom border.
 *   - When scrolling DOWN past 600px: the nav fades out and disables pointer
 *     events. Scrolling UP brings it back. The wordmark and actions always
 *     remain visible.
 *
 * Mobile menu:
 *   - The hamburger toggles a full-screen overlay rendered inside <header>.
 *   - On open/close the overlay, the opaque strip behind the controls (the
 *     mask), and the control colours all crossfade together over 300ms, so the
 *     bar and the menu move as one. The <header> itself stays transparent — the
 *     scroll background lives on the separate bar-bg layer.
 *   - The right-cluster sits on z-[60] (above the z-50 overlay) so the
 *     close (X) icon remains visible and tappable.
 */
import Wordmark from "./Wordmark.astro";
import ThemeToggle from "./ThemeToggle.astro";
import { nav, site } from "../data/site";
import type { NavId } from "../data/site";

interface Props {
  active?: NavId | null;
  /** Home only: the hero is a dark full-bleed image on mobile, so the header
   *  controls flip to white while the bar is transparent at the top (<md). */
  heroOverlay?: boolean;
}
const { active = null, heroOverlay = false }: Props = Astro.props;
---
<header
  x-data="{
    scrolled: false,
    hideNav: false,
    lastY: 0,
    open: false,
    heroOverlay: false,
    onScroll() {
      const y = window.scrollY;
      this.scrolled = y > 40;
      // Direction-based nav hide with an 8px deadzone. Momentum / sub-pixel
      // scroll produces tiny ±1px deltas; without the deadzone every backward
      // tick reads as 'scrolling up' and flips hideNav, restarting the fade
      // each frame (the stutter). Sub-threshold moves are ignored — they
      // accumulate against lastY — so the transition runs once, cleanly.
      const delta = y - this.lastY;
      if (Math.abs(delta) < 8) return;
      this.hideNav = y > 600 && delta > 0;
      this.lastY = y;
    },
    /*
     * The header element is a transparent positioning container — it owns NO
     * background of its own. Two things decouple the bar's appearance from the
     * menu's open/close so they never fight each other:
     *
     *   - The scroll background (tint + blur + hairline) lives on the .bar-bg
     *     layer below. It fades purely on `scrolled` and sits at -z-10, behind
     *     the menu overlay — so opening/closing the menu never triggers a
     *     background transition on the bar (the old source of the open/close
     *     jank). The menu's own opacity fade is the only open/close animation.
     *   - That same .bar-bg is a SIBLING of the fixed menu, not an ancestor,
     *     so its `backdrop-filter` can't establish a containing block for the
     *     menu (which would reposition the fixed overlay relative to the bar
     *     and hide it). Keeping backdrop-filter off the <header> itself is what
     *     lets the full-screen menu resolve against the viewport.
     *
     * So this getter only carries `padding` and the control-colour flip; both
     * are animated by the header's own `transition-[padding,color]` below.
     */
    get headerClass() {
      const padding = this.scrolled ? 'py-3.5' : 'py-5 lg:py-6';
      // Over the dark mobile hero (home), the controls are white while the bar
      // is transparent at the top. Scrolling or opening the menu brings a solid
      // light backing, so they return to dark; the header's `color` transition
      // crossfades the flip in sync with the bar/menu fade.
      const text = (this.heroOverlay && !this.scrolled && !this.open)
        ? 'max-md:text-white'
        : '';
      return `${padding} ${text}`;
    }
  }"
  data-hero={heroOverlay ? "true" : "false"}
  x-init="heroOverlay = $el.dataset.hero === 'true'; onScroll()"
  x-on:scroll.window.passive="onScroll()"
  x-on:keydown.escape.window="open = false"
  x-bind:class="headerClass"
  class="fixed top-0 left-0 right-0 z-50 px-5 sm:px-6 md:px-8 flex lg:grid items-center justify-between lg:justify-normal gap-4 lg:gap-6 lg:[grid-template-columns:1fr_auto_1fr] transition-[padding,color] duration-300"
>
  {/*
    Scroll background — a dedicated layer, NOT the <header>'s own background.
    Two reasons it lives here instead of on the bar:
      - It fades on `scrolled` alone, fully decoupled from the menu's
        open/close, so toggling the menu never animates the bar background
        (the old open/close colour jank). The menu owns that transition.
      - It carries the backdrop-blur. As a SIBLING of the fixed menu (not an
        ancestor), its backdrop-filter can't create a containing block that
        would trap the full-screen overlay. Sitting at -z-10 it stays behind
        the menu, so it's naturally hidden while the menu is up. */}
  <div
    aria-hidden="true"
    x-bind:class="scrolled ? 'opacity-100' : 'opacity-0'"
    class="absolute inset-0 -z-10 bg-bg/85 backdrop-blur-md backdrop-saturate-150 border-b border-hairline transition-opacity duration-300"
  ></div>

  {/*
    Opaque strip behind the controls while the mobile menu is open. The menu
    overlay (z-50) sits BELOW this (z-[55]) and the controls ABOVE (z-[60]), so
    a scrolled-up menu list never shows through the gaps around the logo /
    toggle / hamburger. It fades with the SAME 300ms opacity transition as the
    menu — not an instant snap — so the bar and the menu open/close as one
    motion; the control colours crossfade in step via the header's `color`
    transition, staying legible over the dark mobile hero throughout. */}
  <div
    x-show="open"
    x-cloak
    aria-hidden="true"
    x-transition:enter="transition-opacity duration-300"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition-opacity duration-300"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    class="lg:hidden absolute inset-0 bg-bg z-[55]"
  ></div>

  {/* Wordmark — always visible, links home */}
  <a href="/" class="lg:justify-self-start relative z-[60]" aria-label={`${site.name} — home`}>
    <Wordmark size={24} dot={false} />
  </a>

  {/* Primary nav — desktop only (lg+). Hides on scroll-down. */}
  <nav
    aria-label="Primary"
    x-bind:class="hideNav ? 'opacity-0 pointer-events-none' : 'opacity-100'"
    class="hidden lg:flex justify-center gap-7 font-mono text-xs uppercase transition-opacity duration-300 tracking-mono"
  >
    {nav.map((n, i) => (
      <a
        href={n.href}
        class:list={[
          "hover-line inline-flex items-baseline gap-1.5",
          active === n.id ? "text-text" : "text-text-muted hover:text-text",
        ]}
      >
        <span class="text-micro opacity-60">{String(i + 1).padStart(2, "0")}</span>
        {n.label}
      </a>
    ))}
  </nav>

  {/* Right cluster — availability (desktop only) + theme toggle + hamburger (mobile only).
      z-[60] keeps it stacked above the mobile menu overlay (z-50) so the
      hamburger morphs into a visible close icon while the menu is open. */}
  <div class="lg:justify-self-end flex items-center gap-3 lg:gap-3.5 relative z-[60]">
    <span
      class="hidden lg:inline-flex items-center font-mono text-label uppercase text-text-muted tracking-mono"
    >
      <span
        class="pulse-dot inline-block mr-2 rounded-full bg-accent align-middle size-1.5"
        aria-hidden="true"
      ></span>
      {site.availability}
    </span>
    <ThemeToggle />

    {/* Hamburger — shown below lg. Toggles `open` for the overlay below. */}
    <button
      type="button"
      class="lg:hidden inline-flex items-center justify-center text-inherit size-11 -mr-2.5"
      aria-label="Open menu"
      x-bind:aria-expanded="open ? 'true' : 'false'"
      aria-controls="mobile-menu"
      x-on:click="open = !open"
    >
      <span class="relative block w-5.5 h-3.5" aria-hidden="true">
        <span
          class="absolute left-0 right-0 h-px bg-current transition-transform duration-300"
          x-bind:class="open ? 'top-[6px] rotate-45' : 'top-0 rotate-0'"
        ></span>
        <span
          class="absolute left-0 right-0 h-px bg-current transition-opacity duration-200 top-1.5"
          x-bind:class="open ? 'opacity-0' : 'opacity-100'"
        ></span>
        <span
          class="absolute left-0 right-0 h-px bg-current transition-transform duration-300"
          x-bind:class="open ? 'top-[6px] -rotate-45' : 'top-[12px] rotate-0'"
        ></span>
      </span>
    </button>
  </div>

  {/* ─── Mobile menu overlay ──────────────────────────────────────────────
      Solid bg-bg, z-50 (below the right-cluster's z-[60] so the X icon
      always reads on top). Lives inside <header> so it inherits the Alpine
      scope.

      Two motion notes:
        - Enter and leave both run a 300ms opacity fade, so the X-button and
          Escape close is as smooth as the open. Nav-link closes are the one
          exception: we must NOT let the leave fade run on top of Astro's
          ClientRouter crossfade (that stacks two fades — closing menu +
          incoming page). The before-swap handler below therefore leaves
          `open` untouched during navigation; the menu rides out inside the
          old snapshot and the crossfade carries it away.
        - The overlay carries `transition-colors duration-300` so its
          background eases between light/dark when the theme toggle is
          clicked while the menu is open — without it the overlay would
          snap to the new theme while the body (which DOES have a
          transition) eased, producing a visible mismatch.

      Inner column has `overflow-y-auto` so the nav list + availability
      footer can scroll on short viewports instead of being clipped. */}
  {/*
    Scroll lives on the FIXED parent (not the inner column). With
    overflow-y-auto here and min-h-full on the inner column, short content
    pins to the bottom (footer pushes down via mt-auto) and tall content
    scrolls naturally. The previous setup put overflow-y-auto on the
    element that was itself supposed to grow — overflow-on-self never
    triggers, so the menu stayed clipped at viewport height.

    Nav links do NOT close the menu on click. Astro's ClientRouter captures
    the current document (with the menu visible) as the "old" snapshot and
    crossfades to the new page. The new page's fresh Alpine state has
    `open: false` by default, so the menu disappears as part of the view
    transition — no instant snap + new-page-flash sequence.
  */}
  <div
    id="mobile-menu"
    x-cloak
    x-show="open"
    x-transition:enter="transition-opacity duration-300"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition-opacity duration-300"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    x-bind:class="open ? 'pointer-events-auto' : 'pointer-events-none'"
    class="lg:hidden fixed inset-0 z-50 bg-bg transition-colors duration-300 overflow-y-auto overscroll-contain"
    role="dialog"
    aria-modal="true"
    aria-label="Primary navigation"
  >
    <div class="flex flex-col min-h-full px-5 sm:px-6 pt-24 pb-10">
      <nav aria-label="Primary mobile" class="flex flex-col">
        {nav.map((n, i) => (
          <a
            href={n.href}
            class:list={[
              "flex items-baseline gap-3 py-4 border-b border-hairline font-serif",
              active === n.id ? "text-text" : "text-text",
              "tracking-snug text-title min-h-12",
            ]}
          >
            <span class="font-mono text-label text-text-muted tracking-mono">
              {String(i + 1).padStart(2, "0")}
            </span>
            <span>{n.label}</span>
          </a>
        ))}
      </nav>

      <div class="mt-auto pt-10">
        <p class="font-mono uppercase text-label text-text-muted flex items-center gap-2 tracking-mono">
          <span
            class="pulse-dot inline-block rounded-full bg-accent size-1.5"
            aria-hidden="true"
          ></span>
          {site.availability}
        </p>
        <p class="font-mono uppercase text-micro text-text-muted mt-3 tracking-mono">
          {site.address}
        </p>
      </div>
    </div>
  </div>

  {/*
    Body scroll lock while the mobile menu is open. Teleported to <body> so
    it survives the header's stacking context.

    `astro:before-swap` releases the lock the moment a view transition starts,
    so the incoming page never renders with `overflow: hidden` still on
    <html>. It deliberately does NOT flip `open` — see the overlay's first
    motion note: keeping `open` true through navigation stops the leave fade
    from stacking on ClientRouter's crossfade. The menu stays in the old
    snapshot, the crossfade carries it out, and the fresh page mounts with
    open:false, so it's gone after the swap regardless.
  */}
  <template x-teleport="body">
    <div
      x-effect="document.documentElement.style.overflow = open ? 'hidden' : ''"
      x-init="
        document.addEventListener('astro:before-swap', () => {
          document.documentElement.style.overflow = '';
        });
      "
    ></div>
  </template>
</header>
{/* In-flow spacer to compensate for the fixed header — keeps page content
    from tucking under the bar on first paint before scroll. */}
<div aria-hidden="true" class="h-[72px] lg:h-[88px]"></div>
